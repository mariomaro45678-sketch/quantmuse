{
    "_comment": "Risk config override for small capital accounts (<$100 USD)",

    "capital_tier": "micro",
    "min_capital": 10,
    "max_capital": 100,

    "position_limits": {
        "max_position_size_usd": 50,
        "max_position_pct_per_asset": 0.40,
        "max_leverage_per_asset": 5,
        "max_portfolio_leverage": 3,
        "max_correlated_exposure_pct": 0.60
    },

    "loss_limits": {
        "max_daily_loss_pct": 0.15,
        "max_weekly_loss_pct": 0.25,
        "max_drawdown_pct": 0.30,
        "circuit_breaker_drawdown_pct": 0.20
    },

    "hip3_settings": {
        "_note": "HIP-3 specific settings for builder perps",
        "taker_fee_pct": 0.001,
        "maker_fee_pct": 0.0004,
        "use_isolated_margin": true,
