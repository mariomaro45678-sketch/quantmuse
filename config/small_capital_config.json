        "min_trade_interval_seconds": 300,
        "max_trades_per_hour": 6,
        "prefer_limit_orders": true,
        "slippage_tolerance_pct": 0.002
    },

    "assets_to_trade": {
        "_comment": "Best assets for small capital (low min_order_size)",
        "metals": ["XAU", "XAG"],
        "stocks": ["TSLA", "NVDA", "META"],
        "crypto": []
    },

    "position_sizing": {
        "method": "volatility",
        "target_daily_vol_pct": 0.02,
        "kelly_cap_fraction": 0.15,
        "min_position_usd": 2.0
    }
